generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  phone         String?  @unique
  email         String?  @unique
  name          String?
  role          String   @default("USER") // USER, BUSINESS, ADMIN, COURIER
  kycStatus     String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  walletBalance Float    @default(0.0)
  referralCode  String?  @unique
  password      String?
  createdAt     DateTime @default(now())

  shipments          Shipment[]
  walletTransactions WalletTransaction[]
}

model CourierPartner {
  id       String  @id @default(cuid())
  name     String
  logo     String?
  apiKey   String?
  baseUrl  String?
  isActive Boolean @default(true)
  rating   Float   @default(4.5)

  shipments Shipment[]
  rates     Rate[]
  campaigns Campaign[]
}

model Shipment {
  id               String   @id @default(cuid())
  awbNumber        String   @unique
  userId           String
  pickupAddress    String
  deliveryAddress  String
  courierId        String
  weight           Float
  dimensions       String?
  parcelType       String   @default("PARCEL")
  codAmount        Float    @default(0.0)
  status           String   @default("BOOKED") // BOOKED, PICKUP_PENDING, IN_TRANSIT, OUT_FOR_DELIVERY, DELIVERED, EXCEPTION, RETURNED
  evidenceVaultUrl String?
  evidenceHash     String?
  totalAmount      Float    @default(0.0)
  paymentMethod    String?
  createdAt        DateTime @default(now())

  user             User            @relation(fields: [userId], references: [id])
  courier          CourierPartner  @relation(fields: [courierId], references: [id])
  trackingEvents   TrackingEvent[]
  disputes         Dispute[]
  codTransactions  CODTransaction[]
}

model Rate {
  id                String   @id @default(cuid())
  courierId         String
  pickupPincode     String
  deliveryPincode   String
  weight            Float
  price             Float
  fuelSurcharge     Float
  gst               Float
  etaDays           Int
  actualAvgDays     Int?
  codAvailable      Boolean  @default(false)
  pickupWindowHours Int?
  fetchedAt         DateTime @default(now())

  courier           CourierPartner @relation(fields: [courierId], references: [id])
}

model TrackingEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  status      String
  location    String?
  description String?
  timestamp   DateTime @default(now())

  shipment    Shipment @relation(fields: [shipmentId], references: [id])
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String   // CREDIT, DEBIT
  amount    Float
  reference String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Dispute {
  id          String   @id @default(cuid())
  shipmentId  String
  type        String
  description String?
  proofUrl    String?
  status      String   @default("UNDER_REVIEW") // UNDER_REVIEW, RESOLVED
  resolvedAt  DateTime?

  shipment    Shipment @relation(fields: [shipmentId], references: [id])
}

model CODTransaction {
  id          String   @id @default(cuid())
  shipmentId  String
  amount      Float
  collectedAt DateTime?
  remittedAt  DateTime?
  cycleId     String?

  shipment    Shipment @relation(fields: [shipmentId], references: [id])
}

model Campaign {
  id             String   @id @default(cuid())
  courierId      String
  name           String
  targetPincodes String?
  dailyBudget    Float
  status         String   @default("ACTIVE")
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  bookings       Int      @default(0)

  courier        CourierPartner @relation(fields: [courierId], references: [id])
}
