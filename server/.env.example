# SERVER
NODE_ENV=development
PORT=3001

# POSTGRESQL (local Docker)
DATABASE_URL=postgresql://postgres:swiftroute123@localhost:5432/swiftroute

# MONGODB (local Docker)
MONGODB_URL=mongodb://localhost:27017/swiftroute_tracking

# REDIS (local Docker)
REDIS_URL=redis://localhost:6379

# KAFKA (local Docker)
KAFKA_BROKERS=localhost:9092

# JWT - make up any long random string
JWT_SECRET=
JWT_EXPIRES_IN=7d

# MINIO (local file storage - replaces S3 in development)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=swiftroute
MINIO_SECRET_KEY=swiftroute123
MINIO_BUCKET=evidence-vault

# RAZORPAY (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# MSG91 SMS (get from msg91.com)
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=SWFTRT

# GUPSHUP WHATSAPP (get from gupshup.io)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=SwiftRoute
GUPSHUP_SOURCE_NUMBER=

# FIREBASE (download JSON from console.firebase.google.com)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# DIGIO KYC (get from digio.in)
DIGIO_BASE_URL=https://app.digio.in/api/v2
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=

# PINECONE (get from pinecone.io)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=swiftroute-addresses

# SENDGRID EMAIL (get from sendgrid.com)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@swiftroute.in

# DELHIVERY COURIER (get from Delhivery partner portal)
DELHIVERY_API_KEY=
DELHIVERY_BASE_URL=https://staging-express.delhivery.com

# AWS (for production only - leave blank for now)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=swiftroute-evidence